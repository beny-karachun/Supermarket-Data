# HTTP port
PORT=3000

# SQLite database location (created on first pipeline run)
DB_PATH=./data/database.db

# Where raw feed files are downloaded before ingestion (deleted after load
# unless --keep-files)
DUMPS_DIR=./data/dumps

# Python used by the server to spawn the ingestion pipeline
PIPELINE_PYTHON=.venv/bin/python

# Scheduled ingestion inside the server process (node-cron).
# Alternative: a system crontab line, see README.
ENABLE_CRON=0
CRON_SCHEDULE=0 3 * * *
# Chains for scheduled runs: "all" or comma-separated slugs (pipeline/config.py)
CHAINS=all

# Parallel download processes for the scraper library
SCRAPER_PROCS=4

# Optional cap on files per chain per run (useful for dev; empty = no cap)
SCRAPE_FILE_LIMIT=

# Max Nominatim address-level geocoding lookups per pipeline run
# (1 req/sec; store pins refine across runs and persist in the cache)
GEOCODE_BUDGET=150
